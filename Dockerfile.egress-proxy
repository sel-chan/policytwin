ARG NODE_BASE_IMAGE

FROM ${NODE_BASE_IMAGE} AS build

ARG NODE_BASE_IMAGE
RUN node -e "const image=process.env.NODE_BASE_IMAGE??'';if(!/^node:22\\.22\\.2-[A-Za-z0-9._-]+@sha256:[0-9a-f]{64}$/.test(image)){console.error('NODE_BASE_IMAGE must be an immutable Node 22.22.2 digest.');process.exit(64)}"

WORKDIR /opt/policytwin
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
RUN corepack enable
RUN corepack prepare pnpm@11.7.0 --activate
RUN pnpm install --frozen-lockfile
COPY src ./src
COPY scripts/build-core.mjs scripts/process.mjs ./scripts/
COPY tsconfig.json tsconfig.build.json ./
RUN node scripts/build-core.mjs

FROM ${NODE_BASE_IMAGE} AS runtime

ARG NODE_BASE_IMAGE
RUN node -e "const image=process.env.NODE_BASE_IMAGE??'';if(!/^node:22\\.22\\.2-[A-Za-z0-9._-]+@sha256:[0-9a-f]{64}$/.test(image)){console.error('NODE_BASE_IMAGE must be an immutable Node 22.22.2 digest.');process.exit(64)}"

ENV NODE_ENV=production
WORKDIR /opt/policytwin

COPY --from=build --chown=10003:10003 /opt/policytwin/dist/codex/openai-egress-contract.js ./dist/codex/openai-egress-contract.js
COPY --from=build --chown=10003:10003 /opt/policytwin/dist/codex/openai-egress-proxy.js ./dist/codex/openai-egress-proxy.js
COPY --chown=10003:10003 scripts/openai-egress-proxy.mjs ./scripts/openai-egress-proxy.mjs

USER 10003:10003
ENTRYPOINT ["node", "scripts/openai-egress-proxy.mjs"]
