{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://policytwin.local/schemas/local-challenge-run.v1.schema.json",
  "title": "PolicyTwin local challenge run",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "profile",
    "status",
    "model",
    "surface",
    "authentication",
    "tooling",
    "provenance",
    "repair",
    "commands",
    "policyVerification",
    "review",
    "claims",
    "startedAt",
    "completedAt"
  ],
  "properties": {
    "schemaVersion": { "const": "1" },
    "profile": { "const": "LOCAL_CHALLENGE" },
    "status": { "const": "LOCAL_CHALLENGE_PASS" },
    "model": { "const": "gpt-5.6" },
    "surface": { "const": "CODEX_CLI_OUTPUT_SCHEMA" },
    "authentication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "explicitApiKeyProvided",
        "credentialMaterialCaptured",
        "temporaryAuthCopyCreated",
        "temporaryAuthCopyRemovedBeforeEvidence",
        "temporaryAuthDirectoryRestricted"
      ],
      "properties": {
        "mode": { "const": "EXISTING_CODEX_LOGIN_TEMPORARY_AUTH_COPY" },
        "explicitApiKeyProvided": { "const": false },
        "credentialMaterialCaptured": { "const": false },
        "temporaryAuthCopyCreated": { "const": true },
        "temporaryAuthCopyRemovedBeforeEvidence": { "const": true },
        "temporaryAuthDirectoryRestricted": { "const": true }
      }
    },
    "tooling": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sdkVersion",
        "bundledCliVersion",
        "externalCliVersion",
        "modelMetadataFallbackPhases"
      ],
      "properties": {
        "sdkVersion": { "const": "0.144.6" },
        "bundledCliVersion": { "const": "0.144.6" },
        "externalCliVersion": { "type": "string", "pattern": "^0\\.144\\.[0-9]+$" },
        "modelMetadataFallbackPhases": {
          "type": "array",
          "maxItems": 3,
          "uniqueItems": true,
          "items": { "enum": ["cartography", "repair", "review"] }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runId",
        "repositoryCommit",
        "sourceInputSha256",
        "acceptedPolicyIrSha256",
        "acceptedCorpusSha256",
        "promptSha256s",
        "outputSchemaSha256s"
      ],
      "properties": {
        "runId": { "type": "string", "pattern": "^lc_[0-9a-f]{16}$" },
        "repositoryCommit": { "type": "string", "pattern": "^[0-9a-f]{40,64}$" },
        "sourceInputSha256": { "$ref": "#/$defs/sha256" },
        "acceptedPolicyIrSha256": { "$ref": "#/$defs/sha256" },
        "acceptedCorpusSha256": { "$ref": "#/$defs/sha256" },
        "promptSha256s": { "$ref": "#/$defs/phaseHashes" },
        "outputSchemaSha256s": { "$ref": "#/$defs/phaseHashes" }
      }
    },
    "repair": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "cartographyThreadId",
        "repairThreadIds",
        "changedFiles",
        "preCommandTreeSha256",
        "postCommandTreeSha256",
        "diffSha256"
      ],
      "properties": {
        "status": { "const": "PASS" },
        "cartographyThreadId": { "$ref": "#/$defs/threadId" },
        "repairThreadIds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/threadId" }
        },
        "changedFiles": {
          "const": ["src/refund.ts", "tests/refund.test.mjs"]
        },
        "preCommandTreeSha256": { "$ref": "#/$defs/sha256" },
        "postCommandTreeSha256": { "$ref": "#/$defs/sha256" },
        "diffSha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "commands": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "orderedIds", "receipts", "receiptsSha256"],
      "properties": {
        "status": { "const": "PASS" },
        "orderedIds": { "const": ["fixture-typecheck", "fixture-test"] },
        "receipts": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "$ref": "#/$defs/commandReceipt" }
        },
        "receiptsSha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "policyVerification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "total", "passed", "drift", "results", "resultsSha256"],
      "properties": {
        "status": { "const": "PASS" },
        "total": { "const": 41 },
        "passed": { "const": 41 },
        "drift": { "const": 0 },
        "results": {
          "type": "array",
          "minItems": 41,
          "maxItems": 41,
          "items": { "$ref": "#/$defs/policyResult" }
        },
        "resultsSha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "threadId", "verdict", "blockingFindings"],
      "properties": {
        "status": { "const": "PASS" },
        "threadId": { "$ref": "#/$defs/threadId" },
        "verdict": { "const": "APPROVE" },
        "blockingFindings": { "const": 0 }
      }
    },
    "claims": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "productionIsolationVerified",
        "authoritativeVerifyLive",
        "releaseEvidenceEligible",
        "responsesApiDirectlyVerified",
        "cgroupV2Verified",
        "liveAttestationPresent"
      ],
      "properties": {
        "productionIsolationVerified": { "const": false },
        "authoritativeVerifyLive": { "const": false },
        "releaseEvidenceEligible": { "const": false },
        "responsesApiDirectlyVerified": { "const": false },
        "cgroupV2Verified": { "const": false },
        "liveAttestationPresent": { "const": false }
      }
    },
    "startedAt": { "type": "string", "format": "date-time" },
    "completedAt": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "threadId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{7,255}$" },
    "phaseHashes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cartography", "repair", "review"],
      "properties": {
        "cartography": { "$ref": "#/$defs/sha256" },
        "repair": { "$ref": "#/$defs/sha256" },
        "review": { "$ref": "#/$defs/sha256" }
      }
    },
    "commandReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "commandId",
        "exitCode",
        "timedOut",
        "durationMs",
        "stdout",
        "stderr",
        "outputTruncated",
        "fixtureTreeBeforeSha256",
        "fixtureTreeAfterSha256",
        "attempt",
        "repairRunId"
      ],
      "properties": {
        "schemaVersion": { "const": "1" },
        "commandId": { "enum": ["fixture-typecheck", "fixture-test"] },
        "exitCode": { "const": 0 },
        "timedOut": { "const": false },
        "durationMs": { "type": "integer", "minimum": 0 },
        "stdout": { "type": "string", "maxLength": 4096 },
        "stderr": { "type": "string", "maxLength": 4096 },
        "outputTruncated": { "const": false },
        "fixtureTreeBeforeSha256": { "$ref": "#/$defs/sha256" },
        "fixtureTreeAfterSha256": { "$ref": "#/$defs/sha256" },
        "attempt": { "enum": [1, 2] },
        "repairRunId": { "$ref": "#/$defs/threadId" }
      }
    },
    "policyResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["caseId", "expectedDecision", "actualDecision", "status", "error"],
      "properties": {
        "caseId": { "type": "string", "minLength": 1, "maxLength": 128 },
        "expectedDecision": { "enum": ["ALLOW", "DENY", "REVIEW"] },
        "actualDecision": { "enum": ["ALLOW", "DENY", "REVIEW"] },
        "status": { "const": "PASS" },
        "error": { "const": null }
      }
    }
  }
}
