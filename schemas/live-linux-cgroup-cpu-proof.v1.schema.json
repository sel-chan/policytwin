{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://policytwin.local/schemas/live-linux-cgroup-cpu-proof.v1.schema.json",
  "title": "PolicyTwin live Linux cgroup-v2 three-role CPU proof",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "proofType",
    "status",
    "requestId",
    "runNonce",
    "requestSha256",
    "executionBindingSha256",
    "supervisorRunId",
    "dockerBindingSha256",
    "workerImageDigest",
    "workerPolicySha256",
    "acceptedCorpusSha256",
    "budgetUsec",
    "aggregateUsageUsec",
    "accountingScope",
    "samplingMode",
    "cumulativeAccountingVerified",
    "failStopEnforcementArmed",
    "hardLimitEnforced",
    "overshootBounded",
    "containmentTriggered",
    "controllerStopped",
    "allRoleCgroupsReleased",
    "roles"
  ],
  "properties": {
    "schemaVersion": { "const": "1" },
    "proofType": { "const": "LIVE_LINUX_CGROUP_V2_THREE_ROLE" },
    "status": { "const": "OBSERVED_WITHIN_BUDGET" },
    "requestId": { "type": "string", "pattern": "^[0-9a-f]{32}$" },
    "runNonce": { "type": "string", "pattern": "^[A-Za-z0-9_-]{43}$" },
    "requestSha256": { "$ref": "#/$defs/sha256" },
    "executionBindingSha256": { "$ref": "#/$defs/sha256" },
    "supervisorRunId": {
      "type": "string",
      "minLength": 16,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "dockerBindingSha256": { "$ref": "#/$defs/sha256" },
    "workerImageDigest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "workerPolicySha256": { "$ref": "#/$defs/sha256" },
    "acceptedCorpusSha256": { "$ref": "#/$defs/sha256" },
    "budgetUsec": { "$ref": "#/$defs/uint64Decimal" },
    "aggregateUsageUsec": { "$ref": "#/$defs/uint64Decimal" },
    "accountingScope": { "const": "POST_BASELINE_THREE_ROLE_AGGREGATE" },
    "samplingMode": { "const": "LINUX_CGROUP_V2_EMBEDDED_ROLE_SAMPLES" },
    "cumulativeAccountingVerified": { "const": true },
    "failStopEnforcementArmed": { "const": true },
    "hardLimitEnforced": { "const": false },
    "overshootBounded": { "const": false },
    "containmentTriggered": { "const": false },
    "controllerStopped": { "const": true },
    "allRoleCgroupsReleased": { "const": true },
    "roles": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "prefixItems": [
        {
          "allOf": [
            { "$ref": "#/$defs/role" },
            { "properties": { "role": { "const": "egress" } } }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/role" },
            { "properties": { "role": { "const": "worker" } } }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/role" },
            { "properties": { "role": { "const": "verifier" } } }
          ]
        }
      ],
      "items": false
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "uint64Decimal": {
      "type": "string",
      "pattern": "^(?:0|[1-9][0-9]{0,18}|1[0-7][0-9]{18}|18[0-3][0-9]{17}|184[0-3][0-9]{16}|1844[0-5][0-9]{15}|18446[0-6][0-9]{14}|184467[0-3][0-9]{13}|1844674[0-3][0-9]{12}|184467440[0-6][0-9]{10}|1844674407[0-2][0-9]{9}|18446744073[0-6][0-9]{8}|1844674407370[0-8][0-9]{6}|18446744073709[0-4][0-9]{5}|184467440737095[0-4][0-9]{4}|18446744073709550[0-9]{3}|18446744073709551[0-5][0-9]{2}|1844674407370955160[0-9]|1844674407370955161[0-5])$"
    },
    "role": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "containerId",
        "pid",
        "startedAt",
        "cgroupIdentitySha256",
        "baselineUsageUsec",
        "finalUsageUsec",
        "deltaUsageUsec",
        "sampleCount",
        "samplesUsec",
        "sampleTranscriptSha256",
        "released"
      ],
      "properties": {
        "role": { "enum": ["egress", "worker", "verifier"] },
        "containerId": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "pid": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
        "startedAt": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,9})?Z$"
        },
        "cgroupIdentitySha256": { "$ref": "#/$defs/sha256" },
        "baselineUsageUsec": { "$ref": "#/$defs/uint64Decimal" },
        "finalUsageUsec": { "$ref": "#/$defs/uint64Decimal" },
        "deltaUsageUsec": { "$ref": "#/$defs/uint64Decimal" },
        "sampleCount": { "type": "integer", "minimum": 2, "maximum": 20000 },
        "samplesUsec": {
          "type": "array",
          "minItems": 2,
          "maxItems": 20000,
          "items": { "$ref": "#/$defs/uint64Decimal" }
        },
        "sampleTranscriptSha256": { "$ref": "#/$defs/sha256" },
        "released": { "const": true }
      }
    }
  }
}
