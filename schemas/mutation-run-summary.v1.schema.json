{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://policytwin.local/schemas/mutation-run-summary.v1.schema.json",
  "title": "PolicyTwin mutation run summary v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "executionMode",
    "runId",
    "opaVersion",
    "executableSha256",
    "reportSha256",
    "total",
    "mutantPolicyHashes",
    "opaResultHashes"
  ],
  "properties": {
    "schemaVersion": { "const": "1" },
    "status": { "enum": ["PASS", "FAIL", "NOT_RUN_OPA"] },
    "executionMode": { "enum": ["REFERENCE_EVALUATOR_NOT_OPA", "OPA_CLI"] },
    "runId": { "type": ["string", "null"], "minLength": 16 },
    "opaVersion": { "type": ["string", "null"], "minLength": 1 },
    "executableSha256": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{64}$"
    },
    "reportSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "total": { "type": "integer", "minimum": 1 },
    "mutantPolicyHashes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/policyHash" }
    },
    "opaResultHashes": {
      "type": "array",
      "items": { "$ref": "#/$defs/resultHash" }
    }
  },
  "$defs": {
    "policyHash": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mutantId", "policySha256"],
      "properties": {
        "mutantId": { "type": "string", "minLength": 1 },
        "policySha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "resultHash": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mutantId", "resultsSha256"],
      "properties": {
        "mutantId": { "type": "string", "minLength": 1 },
        "resultsSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    }
  }
}
