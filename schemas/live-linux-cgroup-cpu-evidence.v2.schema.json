        "pid",
        "startedAt",
        "cgroupIdentitySha256",
        "roleBindingSha256",
        "baselineUsageUsec",
        "finalUsageUsec",
        "deltaUsageUsec",
        "sampleCount",
        "samplesUsec",
        "sampleEventSequences",
        "cgroupBoundEventSequence",
        "executionStartedEventSequence",
        "executionStoppedEventSequence",
        "cgroupReleasedEventSequence",
        "released"
      ],
      "properties": {
