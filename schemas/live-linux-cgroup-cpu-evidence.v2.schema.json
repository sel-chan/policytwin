      }
    },
    "failurePair": {
      "oneOf": [
        {
          "properties": {
            "failurePhase": { "const": "ROLE_ADMISSION" },
            "failureCode": { "const": "CGROUP_BIND_FAILED" }
          },
          "required": ["failurePhase", "failureCode"]
        },
        {
          "properties": {
            "failurePhase": { "const": "SAMPLING" },
