            "failureCode": { "const": "CGROUP_RELEASE_FAILED" }
          },
          "required": ["failurePhase", "failureCode"]
        }
      ]
    },
    "event": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["sequence", "monotonicNs", "eventType", "controllerIdentitySha256"],
          "properties": {
            "sequence": { "type": "integer", "minimum": 1, "maximum": 4096 },
            "monotonicNs": { "$ref": "#/$defs/uint64Decimal" },
            "eventType": { "enum": ["CONTROLLER_STARTED", "CONTROLLER_STOPPED"] },
