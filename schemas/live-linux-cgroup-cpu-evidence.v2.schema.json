          "properties": {
            "sequence": { "type": "integer", "minimum": 1, "maximum": 4096 },
            "monotonicNs": { "$ref": "#/$defs/uint64Decimal" },
            "eventType": {
              "enum": [
                "ROLE_CGROUP_BOUND",
                "ROLE_EXECUTION_STARTED",
                "ROLE_EXECUTION_STOPPED",
                "ROLE_CGROUP_RELEASED"
              ]
            },
            "role": { "enum": ["egress", "worker", "verifier"] },
            "roleBindingSha256": { "$ref": "#/$defs/sha256" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "sequence",
            "monotonicNs",
            "eventType",
            "role",
            "roleBindingSha256",
            "sampleIndex",
            "usageUsec"
          ],
          "properties": {
            "sequence": { "type": "integer", "minimum": 1, "maximum": 4096 },
            "monotonicNs": { "$ref": "#/$defs/uint64Decimal" },
            "eventType": { "const": "ROLE_CPU_SAMPLE" },
            "role": { "enum": ["egress", "worker", "verifier"] },
            "roleBindingSha256": { "$ref": "#/$defs/sha256" },
            "sampleIndex": { "type": "integer", "minimum": 0, "maximum": 1023 },
            "usageUsec": { "$ref": "#/$defs/uint64Decimal" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["sequence", "monotonicNs", "eventType", "failurePhase", "failureCode"],
          "allOf": [{ "$ref": "#/$defs/failurePair" }],
          "properties": {
            "sequence": { "type": "integer", "minimum": 1, "maximum": 4096 },
            "monotonicNs": { "$ref": "#/$defs/uint64Decimal" },
            "eventType": { "const": "FAILURE_OBSERVED" },
            "failurePhase": {
              "enum": [
                "ROLE_ADMISSION",
                "SAMPLING",
                "CONTAINMENT",
                "CONTROLLER_STOP",
                "CGROUP_RELEASE"
              ]
            },
            "failureCode": {
              "enum": [
                "CGROUP_BIND_FAILED",
                "CPU_STAT_READ_FAILED",
                "CPU_COUNTER_REGRESSION",
                "ROLE_IDENTITY_DRIFT",
                "CPU_BUDGET_EXCEEDED",
                "CONTAINMENT_ACTION_FAILED",
                "CONTROLLER_STOP_FAILED",
                "CGROUP_RELEASE_FAILED"
              ]
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["sequence", "monotonicNs", "eventType", "action", "result"],
          "properties": {
            "sequence": { "type": "integer", "minimum": 1, "maximum": 4096 },
            "monotonicNs": { "$ref": "#/$defs/uint64Decimal" },
            "eventType": { "const": "CONTAINMENT_ACTION" },
            "action": { "enum": ["FREEZE", "KILL", "REAP"] },
            "result": { "enum": ["SUCCEEDED", "FAILED"] }
          }
        }
      ]
    },
    "containment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "trigger", "freeze", "kill", "reap"],
      "properties": {
        "status": { "enum": ["NOT_REQUIRED", "SUCCEEDED", "INCOMPLETE"] },
        "trigger": { "enum": ["CONTROLLER_FAILURE", "CPU_BUDGET_EXCEEDED", "IDENTITY_DRIFT"] },
        "freeze": { "enum": ["NOT_ATTEMPTED", "SUCCEEDED", "FAILED"] },
        "kill": { "enum": ["NOT_ATTEMPTED", "SUCCEEDED", "FAILED"] },
        "reap": { "enum": ["NOT_ATTEMPTED", "SUCCEEDED", "FAILED"] }
      },
      "oneOf": [
        {
          "properties": {
            "status": { "const": "NOT_REQUIRED" },
            "freeze": { "const": "NOT_ATTEMPTED" },
            "kill": { "const": "NOT_ATTEMPTED" },
            "reap": { "const": "NOT_ATTEMPTED" }
          },
          "required": ["status", "freeze", "kill", "reap"]
        },
        {
          "properties": {
            "status": { "const": "SUCCEEDED" },
            "freeze": { "const": "SUCCEEDED" },
            "kill": { "const": "SUCCEEDED" },
            "reap": { "const": "SUCCEEDED" }
          },
          "required": ["status", "freeze", "kill", "reap"]
        },
        {
          "properties": { "status": { "const": "INCOMPLETE" } },
          "required": ["status"]
        }
      ]
    }
  }
