        "startedAt": {
          "type": "string",
          "format": "date-time",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,9})?Z$"
        },
        "cgroupIdentitySha256": { "$ref": "#/$defs/sha256" },
        "roleBindingSha256": { "$ref": "#/$defs/sha256" },
        "baselineUsageUsec": { "$ref": "#/$defs/uint64Decimal" },
        "finalUsageUsec": { "$ref": "#/$defs/uint64Decimal" },
        "deltaUsageUsec": { "$ref": "#/$defs/uint64Decimal" },
        "sampleCount": { "type": "integer", "minimum": 2, "maximum": 1024 },
        "samplesUsec": {
          "type": "array",
          "minItems": 2,
          "maxItems": 1024,
          "items": { "$ref": "#/$defs/uint64Decimal" }
        },
        "sampleEventSequences": {
          "type": "array",
          "minItems": 2,
          "maxItems": 1024,
          "items": { "type": "integer", "minimum": 1, "maximum": 4096 }
        },
        "cgroupBoundEventSequence": { "type": "integer", "minimum": 1, "maximum": 4096 },
        "executionStartedEventSequence": { "type": "integer", "minimum": 1, "maximum": 4096 },
        "executionStoppedEventSequence": { "type": "integer", "minimum": 1, "maximum": 4096 },
        "cgroupReleasedEventSequence": { "type": "integer", "minimum": 1, "maximum": 4096 },
        "released": { "const": true }
      }
    },
    "nullableUint64": {
      "oneOf": [{ "$ref": "#/$defs/uint64Decimal" }, { "type": "null" }]
    },
    "observedRole": {
      "type": "object",
