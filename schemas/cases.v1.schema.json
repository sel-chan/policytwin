{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://policytwin.local/schemas/cases.v1.schema.json",
  "title": "PolicyTwin case corpus v1",
  "type": "array",
  "items": { "$ref": "#/$defs/policyCase" },
  "$defs": {
    "decision": { "enum": ["ALLOW", "DENY", "REVIEW"] },
    "refundInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["daysSincePurchase", "usageBasisPoints", "promotionalPurchase", "finalSale", "managerApproved", "planType"],
      "properties": {
        "daysSincePurchase": { "type": "integer", "minimum": 0 },
        "usageBasisPoints": { "type": "integer", "minimum": 0 },
        "promotionalPurchase": { "type": "boolean" },
        "finalSale": { "type": "boolean" },
        "managerApproved": { "type": "boolean" },
        "planType": { "enum": ["MONTHLY", "ANNUAL", "ENTERPRISE"] }
      }
    },
    "policyCase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "input", "expectedDecision", "source", "relatedRuleIds", "relatedClauseIds", "rationale"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "input": { "$ref": "#/$defs/refundInput" },
        "expectedDecision": { "$ref": "#/$defs/decision" },
        "source": { "enum": ["USER_GOLDEN", "BOUNDARY", "CONFLICT", "MINIMAL_CONTRAST", "GENERATED", "REGRESSION", "MUTATION_WITNESS"] },
        "relatedRuleIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "relatedClauseIds": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "rationale": { "type": "string", "minLength": 1 }
      }
    }
  }
}
