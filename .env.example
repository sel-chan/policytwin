# Server-side only. Never expose these values to the browser bundle.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
# Explicit live repair model. Required; no implicit personal Codex default is used.
CODEX_MODEL=
# Opt-in for the disposable LOCAL_CHALLENGE Codex SDK run. Setting this permits
# bounded model calls through the existing Codex login; it never enables verify:live.
POLICYTWIN_LOCAL_CHALLENGE_APPROVED=
# High-entropy server-side token required by POST /api/interpret.
POLICYTWIN_RUN_TOKEN=
# JSON object mapping trusted Ed25519 key IDs to PEM public keys. Every key must also
# match its reviewed SPKI SHA-256 fingerprint in config/attestation-trust.v1.json.
# Never store private keys here.
POLICYTWIN_ATTESTATION_PUBLIC_KEYS_JSON=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Exact browser-facing origin used for mutation origin checks. HTTPS is required in production.
POLICYTWIN_PUBLIC_ORIGIN=http://localhost:3000

# Optional local/runtime overrides.
OPA_PATH=
# Optional test-only OpenSSL executable override for ephemeral mTLS certificates.
OPENSSL_PATH=
# Canonical absolute Docker CLI path required by worker:verify and egress:verify.
POLICYTWIN_DOCKER_CLI=
# Optional local media-tool paths used only to render the challenge video.
POLICYTWIN_FFMPEG_PATH=
POLICYTWIN_FFPROBE_PATH=
# Absolute SQLite file path. Defaults to .data/policytwin.sqlite.
POLICYTWIN_DATABASE_PATH=
POLICYTWIN_REPAIR_RUN_DATABASE_PATH=
# Reserved for the future external live Codex worker. The mTLS transport and
# supervisor contract exist, but no OS-isolated SDK worker consumes these values yet.
POLICYTWIN_CODEX_CARTOGRAPHY_TIMEOUT_MS=90000
POLICYTWIN_CODEX_REPAIR_TIMEOUT_MS=180000
POLICYTWIN_CODEX_REVIEW_TIMEOUT_MS=90000
